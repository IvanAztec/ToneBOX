// Prisma Schema for SaaS Application
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// User model
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?
  avatar        String?
  role          String    @default("user")
  whatsapp      String?   // Prioridad para captura de leads
  estimatedConsumptionRate Float? // Tasa de consumo estimada (páginas/día)
  emailVerified DateTime?
  
  // Relations
  workspaces    WorkspaceMember[]
  ownedWorkspaces Workspace[] @relation("WorkspaceOwner")
  invitesSent   Invite[]   @relation("InvitesSent")
  
  // Timestamps
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@map("users")
}

// Workspace model (for multi-tenancy)
model Workspace {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  plan        String    @default("free")
  settings    Json?
  
  // Owner relation
  ownerId     String
  owner       User      @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  
  // Relations
  members     WorkspaceMember[]
  invites     Invite[]
  subscription Subscription?
  
  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@map("workspaces")
}

// Workspace membership (many-to-many)
model WorkspaceMember {
  id          String    @id @default(cuid())
  role        String    @default("member")
  
  // Relations
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  // Timestamps
  joinedAt    DateTime  @default(now())
  
  @@unique([userId, workspaceId])
  @@map("workspace_members")
}

// Invitation model
model Invite {
  id          String    @id @default(cuid())
  email       String
  role        String    @default("member")
  token       String    @unique
  
  // Relations
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedById String
  invitedBy   User      @relation("InvitesSent", fields: [invitedById], references: [id])
  
  // Timestamps
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  
  @@map("invites")
}

// Subscription model (Stripe)
model Subscription {
  id                   String    @id @default(cuid())
  stripeCustomerId     String    @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  status               String    @default("inactive")
  
  // Relations
  workspaceId          String    @unique
  workspace            Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  // Period
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  
  // Timestamps
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  
  @@map("subscriptions")
}

// Audit Log model
model AuditLog {
  id          String    @id @default(cuid())
  action      String
  entity      String
  entityId    String
  userId      String?
  workspaceId String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  
  // Timestamps
  createdAt   DateTime  @default(now())
  
  @@index([entity, entityId])
  @@index([userId])
  @@index([workspaceId])
  @@map("audit_logs")
}

// Provider model (logistics vendors)
model Provider {
  id                   String                  @id @default(cuid())
  name                 String
  code                 String                  @unique
  dispatchType         DispatchType            @default(DIRECT)
  defaultWeightLimitKg Float                   @default(0)
  defaultShippingCost  Float                   @default(0)
  active               Boolean                 @default(true)

  // Relations
  shippingRules        ProviderShippingRule[]
  products             Product[]

  // Timestamps
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  @@map("providers")
}

// Shipping rules per provider (weight ranges, costs, overrides)
model ProviderShippingRule {
  id                   String       @id @default(cuid())
  providerId           String
  minWeightKg          Float        @default(0)
  maxWeightKg          Float?
  shippingCost         Float
  dispatchTypeOverride DispatchType?
  isDefault            Boolean      @default(false)

  // Relations
  provider             Provider     @relation(fields: [providerId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // Timestamps
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@unique([providerId, minWeightKg, maxWeightKg], name: "provider_weight_range")
  @@index([providerId, isDefault])
  @@map("provider_shipping_rules")
}

// Product model (inventory items linked to providers)
model Product {
  id          String    @id @default(cuid())
  sku         String    @unique
  name        String
  brand       String?   // Marca (HP, Brother, etc.)
  category    String?   // Toner, Ink, Drum, etc.
  color       String?   // Black, Cyan, etc.
  yield       Int?      // Rendimiento de páginas
  compatibility String[] @default([]) // Modelos de impresoras compatibles
  
  providerId  String
  providerSku String?
  weightKg    Float

  // Relations
  provider    Provider  @relation(fields: [providerId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("products")
}

// Product bundle model (Toner + Drum pairings, Duo Packs)
model ProductBundle {
  id          String   @id @default(cuid())
  name        String
  description String?
  tonerId     String
  drumId      String
  price       Float?   // Optional bundle special price
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("product_bundles")
}

// Replenishment subscription system
model ReplenishmentSubscription {
  id           String    @id @default(cuid())
  userId       String
  productId    String
  printerModel String?
  
  status       String    @default("active") // active, paused, cancelled
  
  // Consumption Logic
  yield        Int       // Total pages expected (e.g., 1500)
  consumptionRate Float  // User specific rate (pages/day)
  lastRefillDate DateTime @default(now())
  nextReminderDate DateTime
  
  // Timestamps
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
  @@index([nextReminderDate])
  @@map("replenishment_subscriptions")
}

// Search Log model to track missed opportunities
model SearchLog {
  id           String   @id @default(cuid())
  query        String
  resultsCount Int      @default(0)
  isPotentialProduct Boolean @default(false) // Indica si parece un modelo real (ej. TN-660) o basura
  metadata     Json?    // Para guardar info extra como marca detectada o categoría sugerida
  userId       String?
  ipAddress    String?
  
  // Timestamps
  createdAt    DateTime @default(now())

  @@index([query])
  @@map("search_logs")
}

// Dispatch type for providers and rules
enum DispatchType {
  DIRECT
  PICKUP
  MIXED
}