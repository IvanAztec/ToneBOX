// Prisma Schema for SaaS Application
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// User model
model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  password       String?
  avatar         String?
  role           String    @default("user")
  whatsapp       String?
  customerNumber Int       @unique @default(autoincrement())
  estimatedConsumptionRate Float?
  emailVerified  DateTime?

  // Profile — SaaS Factory Data Engine
  empresa        String?
  cargo          String?
  ciudad         String?
  estado         String?
  origenUTM      String?

  // Relations
  workspaces     WorkspaceMember[]
  ownedWorkspaces Workspace[] @relation("WorkspaceOwner")
  invitesSent    Invite[]   @relation("InvitesSent")
  orders         Order[]
  
  // Timestamps
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  
  @@map("users")
}

// Modelo de Órdenes — Folio formato TB-[orderNumber]
model Order {
  id            String    @id @default(cuid())
  orderNumber   Int       @unique @default(autoincrement())
  folio         String    @unique
  
  userId        String?
  user          User?     @relation(fields: [userId], references: [id])
  
  productName   String
  amount        Float
  currency      String    @default("MXN")
  status        String    @default("PENDING")
  paymentMethod String    @default("PENDING")
  clientName    String?
  clientContact String?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([folio])
  @@map("orders")
}

// Idempotencia Stripe — Evita procesar el mismo evento dos veces
model ProcessedStripeEvent {
  id          String   @id
  type        String
  processedAt DateTime @default(now())

  @@map("processed_stripe_events")
}

// Workspace model (for multi-tenancy)
model Workspace {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  plan        String    @default("free")
  settings    Json?
  
  // Multi-SaaS Orchestration
  projectId   String?
  project     SaaSProject? @relation(fields: [projectId], references: [id])
  
  // Owner relation
  ownerId     String
  owner       User      @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  
  // Relations
  members     WorkspaceMember[]
  invites     Invite[]
  subscription Subscription?
  
  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@map("workspaces")
}

// Multi-SaaS Master Orchestrator
model SaaSProject {
  id          String    @id @default(cuid())
  name        String    // e.g., "ToneBOX"
  description String?
  brandColor  String?
  active      Boolean   @default(true)

  // Relations
  workspaces  Workspace[]
  marketing   MarketingConfig?
  analytics   AnalyticsEvent[]

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("saas_projects")
}

// Conversion Analytics
model AnalyticsEvent {
  id          String    @id @default(cuid())
  type        String    // VISIT, CLICK
  category    String    // WHATSAPP, HERO, CHECKOUT
  metadata    Json?
  
  projectId   String
  project     SaaSProject @relation(fields: [projectId], references: [id])
  
  workspaceId String?
  userId      String?
  
  // Timestamps
  createdAt   DateTime  @default(now())

  @@index([projectId, type])
  @@map("analytics_events")
}

// Marketing Tracking Configuration
model MarketingConfig {
  id            String    @id @default(cuid())
  projectId     String    @unique
  project       SaaSProject @relation(fields: [projectId], references: [id])

  googleAdsId   String?
  fbPixelId     String?
  tagManagerId  String?
  tiktokPixelId String?

  // Timestamps
  updatedAt     DateTime  @updatedAt

  @@map("marketing_configs")
}

// Workspace membership (many-to-many)
model WorkspaceMember {
  id          String    @id @default(cuid())
  role        String    @default("member")
  
  // Relations
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  // Timestamps
  joinedAt    DateTime  @default(now())
  
  @@unique([userId, workspaceId])
  @@map("workspace_members")
}

// Invitation model
model Invite {
  id          String    @id @default(cuid())
  email       String
  role        String    @default("member")
  token       String    @unique
  
  // Relations
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedById String
  invitedBy   User      @relation("InvitesSent", fields: [invitedById], references: [id])
  
  // Timestamps
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  
  @@map("invites")
}

// Subscription model (Stripe)
model Subscription {
  id                   String    @id @default(cuid())
  stripeCustomerId     String    @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  status               String    @default("inactive")
  
  // Relations
  workspaceId          String    @unique
  workspace            Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  // Period
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  
  // Timestamps
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  
  @@map("subscriptions")
}

// Audit Log model
model AuditLog {
  id          String    @id @default(cuid())
  action      String
  entity      String
  entityId    String
  userId      String?
  workspaceId String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  
  // Timestamps
  createdAt   DateTime  @default(now())
  
  @@index([entity, entityId])
  @@index([userId])
  @@index([workspaceId])
  @@map("audit_logs")
}

// Provider model (logistics vendors)
model Provider {
  id                   String                  @id @default(cuid())
  name                 String
  code                 String                  @unique
  dispatchType         DispatchType            @default(DIRECT)
  defaultWeightLimitKg Float                   @default(0)
  defaultShippingCost  Float                   @default(0)
  active               Boolean                 @default(true)

  // Relations
  shippingRules        ProviderShippingRule[]
  products             Product[]

  // Timestamps
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  @@map("providers")
}

// Shipping rules per provider (weight ranges, costs, overrides)
model ProviderShippingRule {
  id                   String       @id @default(cuid())
  providerId           String
  minWeightKg          Float        @default(0)
  maxWeightKg          Float?
  shippingCost         Float
  dispatchTypeOverride DispatchType?
  isDefault            Boolean      @default(false)

  // Relations
  provider             Provider     @relation(fields: [providerId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // Timestamps
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@unique([providerId, minWeightKg, maxWeightKg], name: "provider_weight_range")
  @@index([providerId, isDefault])
  @@map("provider_shipping_rules")
}

// Product model (inventory items linked to providers)
model Product {
  id                 String    @id @default(cuid())
  sku                String    @unique
  name               String
  brand              String?   // Marca (HP, Brother, etc.)
  category           String?   // Toner, Ink, Drum, etc.
  color              String?   // Black, Cyan, etc.
  yield              Int?      // Rendimiento de páginas
  compatibility      String[]  @default([]) // Modelos de impresoras compatibles
  availabilityStatus String    @default("IN_STOCK") // IN_STOCK | ON_DEMAND | OUT_OF_STOCK
  productType String    @default("ORIGINAL")   // ORIGINAL | COMPATIBLE | HARDWARE
  costPrice   Float?   // Costo proveedor (PRIVADO — nunca al frontend)
  publicPrice Float?   // Precio público = costPrice * margen * 1.04
  speiPrice   Float?   // Precio SPEI = costPrice * margen (sin comisión 1.04)
  image       String?  // URL imagen CT

  providerId  String
  providerSku String?
  weightKg    Float

  // Relations
  provider    Provider  @relation(fields: [providerId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("products")
}

// Product bundle model (Duo Pack, TriPack, Pack Business Start)
model ProductBundle {
  id                 String   @id @default(cuid())
  name               String
  description        String?
  comboType          String   @default("DUO_PACK") // DUO_PACK | TRIPACK | BUSINESS_START
  tonerId            String
  drumId             String
  toner2Id           String?  // Segundo tóner (TriPack: 2 Toners + 1 Drum)
  hardwareId         String?  // Hardware para Pack Business Start
  price              Float?   // Precio público del bundle (publicPrices * descuento)
  speiPrice          Float?   // Precio SPEI = price / 1.04
  freeShipping       Boolean  @default(false) // Envío gratis — combos 2+ consumibles
  availabilityStatus String   @default("IN_STOCK") // IN_STOCK | ON_DEMAND | OUT_OF_STOCK

  // Timestamps
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("product_bundles")
}

// Replenishment subscription system
model ReplenishmentSubscription {
  id           String    @id @default(cuid())
  userId       String
  productId    String
  printerModel String?
  
  status       String    @default("active") // active, paused, cancelled
  
  // Consumption Logic
  yield        Int       // Total pages expected (e.g., 1500)
  consumptionRate Float  // User specific rate (pages/day)
  lastRefillDate DateTime @default(now())
  nextReminderDate DateTime
  
  // Timestamps
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
  @@index([nextReminderDate])
  @@map("replenishment_subscriptions")
}

// Search Log model to track missed opportunities
model SearchLog {
  id           String   @id @default(cuid())
  query        String
  resultsCount Int      @default(0)
  isPotentialProduct Boolean @default(false)
  metadata     Json?
  userId       String?
  ipAddress    String?
  
  // Timestamps
  createdAt    DateTime @default(now())

  @@index([query])
  @@map("search_logs")
}

// Auto-blindaje: Alertas de productos en demanda que no existen en el catálogo
model CatalogAlert {
  id            String   @id @default(cuid())
  query         String   @unique  // El término buscado (normalizado)
  hitCount      Int      @default(1)
  detectedBrand String?
  detectedType  String?  // toner, ink, drum, etc.
  confidence    String   @default("medium") // low, medium, high
  priority      String   @default("MEDIUM") // MEDIUM, HIGH, CRITICAL
  status        String   @default("PENDING") // PENDING, PROMOTED, DISMISSED

  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, priority])
  @@map("catalog_alerts")
}

// Borradores de producto generados por el sistema a partir de CatalogAlerts
model ProductDraft {
  id             String   @id @default(cuid())
  suggestedSku   String
  suggestedName  String
  brand          String?
  category       String?
  status         String   @default("PENDING_REVIEW") // PENDING_REVIEW, APPROVED, REJECTED
  sourceAlertId  String?
  demandScore    Int      @default(0) // Número de búsquedas que lo generaron

  // Timestamps
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("product_drafts")
}


// Registro de pagos SPEI - Ciclo: PENDING_VALIDATION -> APPROVED
model SpeiPayment {
  id            String    @id @default(cuid())
  orderId       String
  amount        Float
  productName   String?
  trackingKey   String?
  status        String    @default("PENDING_VALIDATION")
  clientContact String?
  approvedAt    DateTime?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([orderId])
  @@map("spei_payments")
}

// Lead de captura de demanda - Productos sin stock o inexistentes
model DemandCaptureLead {
  id            String    @id @default(cuid())
  query         String
  name          String?
  contact       String
  contactType   String    @default("whatsapp")
  status        String    @default("PENDING")
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([query])
  @@index([status])
  @@map("demand_capture_leads")
}
// Dispatch type for providers and rules
enum DispatchType {
  DIRECT
  PICKUP
  MIXED
}